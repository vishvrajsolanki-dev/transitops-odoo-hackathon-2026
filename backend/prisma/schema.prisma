generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  fleet_manager
  driver
  safety_officer
  financial_analyst

  @@map("role")
}

enum VehicleStatus {
  available
  on_trip
  in_shop
  retired

  @@map("vehicle_status")
}

enum DriverStatus {
  available
  on_trip
  off_duty
  suspended

  @@map("driver_status")
}

enum TripStatus {
  draft
  dispatched
  completed
  cancelled

  @@map("trip_status")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  driver             Driver?
  createdTrips       Trip[]           @relation("TripCreatedBy")
  createdMaintenance MaintenanceLog[] @relation("MaintenanceCreatedBy")
  createdFuelLogs    FuelLog[]        @relation("FuelLogCreatedBy")
  createdExpenses    Expense[]        @relation("ExpenseCreatedBy")
  safetyScoreChanges SafetyScoreLog[] @relation("SafetyScoreChangedBy")

  @@map("users")
}

model Driver {
  id              String       @id @default(uuid())
  userId          String       @unique @map("user_id")
  name            String
  licenseNumber   String       @unique @map("license_number")
  licenseCategory String       @map("license_category")
  licenseExpiry   DateTime     @map("license_expiry")
  contactNumber   String       @map("contact_number")
  safetyScore     Int          @default(100) @map("safety_score")
  status          DriverStatus @default(available)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id])
  trips           Trip[]
  safetyScoreLogs SafetyScoreLog[]

  @@map("drivers")
}

model Vehicle {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique @map("registration_number")
  model              String
  type               String
  region             String
  maxLoadCapacity    Decimal       @map("max_load_capacity") @db.Decimal(10, 2)
  odometer           Decimal       @db.Decimal(10, 2)
  acquisitionCost    Decimal       @map("acquisition_cost") @db.Decimal(12, 2)
  status             VehicleStatus @default(available)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@map("vehicles")
}

model Trip {
  id              String     @id @default(uuid())
  source          String
  destination     String
  cargoWeight     Decimal    @map("cargo_weight") @db.Decimal(10, 2)
  plannedDistance Decimal    @map("planned_distance") @db.Decimal(10, 2)
  actualDistance  Decimal?   @map("actual_distance") @db.Decimal(10, 2)
  revenue         Decimal?   @db.Decimal(12, 2)
  status          TripStatus @default(draft)
  vehicleId       String     @map("vehicle_id")
  driverId        String     @map("driver_id")
  createdByUserId String     @map("created_by_user_id")
  dispatchedAt    DateTime?  @map("dispatched_at")
  completedAt     DateTime?  @map("completed_at")
  cancelledAt     DateTime?  @map("cancelled_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  driver    Driver    @relation(fields: [driverId], references: [id])
  createdBy User      @relation("TripCreatedBy", fields: [createdByUserId], references: [id])
  fuelLogs  FuelLog[]

  @@map("trips")
}

model MaintenanceLog {
  id              String    @id @default(uuid())
  vehicleId       String    @map("vehicle_id")
  description     String
  cost            Decimal?  @db.Decimal(10, 2)
  openedAt        DateTime  @default(now()) @map("opened_at")
  closedAt        DateTime? @map("closed_at")
  createdByUserId String    @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  createdBy User    @relation("MaintenanceCreatedBy", fields: [createdByUserId], references: [id])

  @@map("maintenance_logs")
}

model FuelLog {
  id              String   @id @default(uuid())
  vehicleId       String   @map("vehicle_id")
  tripId          String?  @map("trip_id")
  liters          Decimal  @db.Decimal(10, 2)
  cost            Decimal  @db.Decimal(10, 2)
  date            DateTime
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  trip      Trip?   @relation(fields: [tripId], references: [id])
  createdBy User    @relation("FuelLogCreatedBy", fields: [createdByUserId], references: [id])

  @@map("fuel_logs")
}

model Expense {
  id              String   @id @default(uuid())
  vehicleId       String   @map("vehicle_id")
  category        String
  amount          Decimal  @db.Decimal(10, 2)
  date            DateTime
  description     String?
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  createdBy User    @relation("ExpenseCreatedBy", fields: [createdByUserId], references: [id])

  @@map("expenses")
}

model SafetyScoreLog {
  id              String   @id @default(uuid())
  driverId        String   @map("driver_id")
  oldScore        Int      @map("old_score")
  newScore        Int      @map("new_score")
  reason          String
  changedByUserId String   @map("changed_by_user_id")
  timestamp       DateTime @default(now())

  driver    Driver @relation(fields: [driverId], references: [id])
  changedBy User   @relation("SafetyScoreChangedBy", fields: [changedByUserId], references: [id])

  @@map("safety_score_logs")
}